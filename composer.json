{
    "name": "moxso/laravel-scaleway-tem",
    "description": "A Laravel mailer driver for sending transactional emails through Scaleway TEM.",
    "keywords": [
        "moxso",
        "laravel",
        "laravel-scaleway-tem"
    ],
    "homepage": "https://github.com/moxso/laravel-scaleway-tem",
    "license": "MIT",
    "authors": [
        {
            "name": "Moxso",
            "email": "support@moxso.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/http-client": "^8.0",
        "symfony/scaleway-mailer": "^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0.0||^9.0.0"
    },
    "autoload": {
        "psr-4": {
            "Moxso\\LaravelScalewayTem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moxso\\LaravelScalewayTem\\LaravelScalewayTemServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
